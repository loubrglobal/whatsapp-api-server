# Configuração básica da API
META_GRAPH_VERSION=v23.0
META_GRAPH_BASE_URL=https://graph.facebook.com/v23.0
DATABASE_PATH=/home/ubuntu/whatsapp-api-server/data/whatsapp_api.sqlite3

# Segurança administrativa da API própria
# Gere um valor forte e use nas chamadas internas como: Authorization: Bearer <API_ADMIN_TOKEN>
API_ADMIN_TOKEN=trocar-por-token-administrativo-forte

# Webhook Meta
# Este valor será informado no painel Meta Developers ao validar o webhook.
META_VERIFY_TOKEN=trocar-por-token-de-verificacao-do-webhook

# Se configurado, a API valida X-Hub-Signature-256 dos webhooks recebidos.
META_APP_SECRET=

# Credenciais Meta/WhatsApp Cloud API
# Token de usuário do sistema com whatsapp_business_management e whatsapp_business_messaging.
META_ACCESS_TOKEN=

# IDs padrão, opcionais. Podem ser informados por endpoint também.
DEFAULT_WABA_ID=
DEFAULT_PHONE_NUMBER_ID=1170269502835043

# Meta Ads — leitura e diagnóstico
# Token precisa incluir ads_read para leitura e ads_management apenas quando houver operações de escrita autorizadas.
DEFAULT_META_BUSINESS_IDS=787359667246944,1253178860074961,1017258380516985,1445971609712721,3916373278615789
DEFAULT_AD_ACCOUNT_IDS=

# Trava global para criação/edição de campanhas. Mantenha false até confirmação explícita.
META_ADS_WRITE_ENABLED=false

# Registro operacional: campanhas, anúncios, números WhatsApp e mensagens reais exigem confirmação explícita do usuário.
REQUIRE_EXPLICIT_USER_CONFIRMATION=true
META_ADS_WRITE_CONFIRMATION_PHRASE="CONFIRMO ALTERAR META ADS"
